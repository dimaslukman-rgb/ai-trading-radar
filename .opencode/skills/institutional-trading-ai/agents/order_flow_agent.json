{
  "agent_id": "order_flow_agent",
  "role": "Order Flow Analyst",
  "version": "1.0.0",
  "description": "Menganalisis order flow — buying/selling pressure, delta, aggressive buyers vs sellers.",

  "responsibilities": [
    "Mengevaluasi Buying Pressure",
    "Mengevaluasi Selling Pressure",
    "Menganalisis Delta (buy volume - sell volume)",
    "Mengukur Aggressive Buyers",
    "Mengukur Aggressive Sellers"
  ],

  "evaluations": [
    "Buying Pressure",
    "Selling Pressure",
    "Delta",
    "Aggressive Buyers",
    "Aggressive Sellers"
  ],

  "output_schema": {
    "type": "object",
    "properties": {
      "flow": {
        "type": "string",
        "enum": ["Bullish", "Bearish", "Neutral"],
        "description": "Arah order flow secara keseluruhan"
      },
      "buyers": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100,
        "description": "Persentase aggressive buyers (0-100)"
      },
      "sellers": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100,
        "description": "Persentase aggressive sellers (0-100)"
      },
      "strength": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100,
        "description": "Kekuatan dominasi order flow (0-100)"
      }
    },
    "required": ["flow", "buyers", "sellers", "strength"]
  },

  "rules": [
    "Hanya return JSON, tidak boleh tambahan teks apapun",
    "buyers + sellers tidak harus = 100, masing-masing independent",
    "Fokus pada volume dan agresivitas order, bukan price action",
    "Output harus valid JSON sesuai schema"
  ]
}
