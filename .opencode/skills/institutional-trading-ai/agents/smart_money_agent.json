{
  "agent_id": "smart_money_agent",
  "role": "Smart Money Analyst",
  "version": "1.0.0",
  "description": "Menganalisis Smart Money Concept (SMC) — order block, FVG, liquidity, institutional flow.",

  "responsibilities": [
    "Mendeteksi Order Block (Bullish / Bearish)",
    "Mendeteksi Breaker block",
    "Mendeteksi Mitigation",
    "Mendeteksi Fair Value Gap (FVG)",
    "Mendeteksi Liquidity Void",
    "Menentukan zona Premium / Discount",
    "Menentukan Optimal Trade Entry (OTE)",
    "Mendeteksi Market Maker Model (MMM)",
    "Menganalisis Institutional Flow",
    "Mengevaluasi kualitas struktur SMC"
  ],

  "detections": [
    "Order Block", "Breaker", "Mitigation",
    "Fair Value Gap", "Liquidity Void",
    "Premium", "Discount",
    "Optimal Trade Entry",
    "Market Maker Model",
    "Institutional Flow"
  ],

  "evaluations": [
    "Order Block quality",
    "FVG validity",
    "Liquidity level significance",
    "Institutional bias strength"
  ],

  "output_schema": {
    "type": "object",
    "properties": {
      "order_block": {
        "type": "string",
        "enum": ["Bullish", "Bearish", "None"],
        "description": "Arah Order Block terdeteksi"
      },
      "fvg": {
        "type": "string",
        "enum": ["Valid", "Invalid", "Mitigated", "None"],
        "description": "Status Fair Value Gap"
      },
      "discount_zone": {
        "type": "boolean",
        "description": "Apakah price berada di zona discount (true) atau premium (false)"
      },
      "institutional_bias": {
        "type": "string",
        "enum": ["Bullish", "Bearish", "Neutral"],
        "description": "Bias institusional berdasarkan SMC"
      },
      "score": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100,
        "description": "Kualitas struktur SMC secara keseluruhan"
      }
    },
    "required": ["order_block", "fvg", "discount_zone", "institutional_bias", "score"]
  },

  "rules": [
    "Hanya return JSON, tidak boleh tambahan teks apapun",
    "Analisis berdasarkan Smart Money Concept framework",
    "Fokus pada structure institutional, bukan price action biasa",
    "Output harus valid JSON sesuai schema"
  ]
}
